<body>
    <header>
        Fashion Outfit Recommender
    </header>
    
    <main>
        <section id="upload-section">
            <h2>Upload Your Wardrobe</h2>
            <input type="file" id="imageUpload" accept="image/*">
            <button onclick="uploadImage()">Upload</button>
            <div id="wardrobe"></div>
        </section>
        
        <section id="recommend-section">
            <h2>Get Outfit Recommendations</h2>
            <label for="weather">Select Weather:</label>
            <select id="weather">
                <option value="hot">Hot</option>
                <option value="cold">Cold</option>
                <option value="rainy">Rainy</option>
            </select>
            
            <label for="occasion">Select Occasion:</label>
            <select id="occasion">
                <option value="casual">Casual</option>
                <option value="formal">Formal</option>
                <option value="party">Party</option>
            </select>
            
            <button onclick="generateOutfit()">Generate Outfit</button>
            <div id="outfitSuggestion"></div>
        </section>
    </main>
    
    <script>
        function uploadImage() {
            const input = document.getElementById('imageUpload');
            const wardrobe = document.getElementById('wardrobe');
            
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const imgDiv = document.createElement('div');
                    imgDiv.classList.add('clothing-item');
                    imgDiv.style.backgroundImage = `url(${e.target.result})`;
                    wardrobe.appendChild(imgDiv);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
        
        function generateOutfit() {
            const weather = document.getElementById('weather').value;
            const occasion = document.getElementById('occasion').value;
            const outfitSuggestion = document.getElementById('outfitSuggestion');
            
            const outfits = {
                hot: {
                    casual: "T-shirt and Shorts",
                    formal: "Linen Shirt and Chinos",
                    party: "Polo Shirt and Slim Fit Jeans"
                },
                cold: {
                    casual: "Hoodie and Jeans",
                    formal: "Blazer and Trousers",
                    party: "Sweater and Stylish Pants"
                },
                rainy: {
                    casual: "Waterproof Jacket and Jeans",
                    formal: "Trench Coat and Suit",
                    party: "Denim Jacket and Sneakers"
                }
            };
            
            outfitSuggestion.innerHTML = `<h3 style="color:#ff758c;">Recommended Outfit: ${outfits[weather][occasion]}</h3>`;
        }
    </script>
